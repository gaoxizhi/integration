<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.gaox.user.mapper.UserMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="net.gaox.domain.entity.User">
        <id column="id" property="id" />
        <result column="name" property="name" />
        <result column="member" property="member" />
        <result column="real_name" property="realName" />
        <result column="phone_num" property="phoneNum" />
        <result column="qq" property="qq" />
        <result column="email" property="email" />
        <result column="avatar" property="avatar" />
        <result column="id_card_num" property="idCardNum" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
        <result column="salt" property="salt" />
        <result column="passwd" property="passwd" />
        <result column="able" property="able" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, name, member, real_name, phone_num, qq, email, avatar, id_card_num, create_time, update_time, salt, passwd, able
    </sql>

</mapper>
