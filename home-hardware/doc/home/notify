spring:
  # 数据库
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    username: root
    password: root
    url: jdbc:mysql://localhost:3306/iot?serverTimezone=GMT%2B8&characterEncoding=utf-8&useSSL=false&useUnicode=true

  # es 集群配置方式
  elasticsearch:
    rest:
      uris: http://localhost:9200
      username: admin
      password: password
  # 配置Redis
  redis:
    # 服务器地址
    host: localhost
    # 服务器端口
    port:
    # Redis密码
    password:
    # 连接超时时间
    timeout: 60s
    # 连接池最大连接数（使用负值表示没有限制）
    lettuce:
      pool:
        max-active: 50
        # 连接池中的最小空闲连接
        min-idle: 5
        # 连接池中的最大空闲连接
        max-idle: 50
        # 连接池最大阻塞等待时间（使用负值表示没有限制）
        max-wait: 5000

canal:
  #canal的地址
  server: 127.0.0.1:11111
  #数据同步的目的地
  destination: iot

seata:
  # 事务组名称
  tx-service-group: home-seata
  service:
    # 事务组与cluster的映射关系
    vgroup-mapping:
      home-seata: gaoxizhi
  data-source-proxy-mode: XA
  application-id: ${spring.application.name}
  # enable-auto-data-source-proxy: false
  # TC服务注册中心的配置，微服务根据这些信息去注册中心获取tc服务地址
  registry:
    # 注册中心类型 nacos
    type: nacos
    nacos:
      # nacos地址
      server-addr: 127.0.0.1:8848
      # namespace，默认为空
      namespace: gaox
      # 分组，默认是DEFAULT_GROUP
      group: home
      # seata服务名称
      application: seata-server
      username: nacos
      password: nacos

mybatis-plus:
  typeAliasesPackage: net.gaox.domain.entity
  mapper-locations: classpath:/mybatis/**/*Mapper.xml
  configuration:
    map-underscore-to-camel-case: true
logging:
  level.net.gaox.notify: debug