spring:
  # 数据库
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    username: root
    password: root
    url: jdbc:mysql://localhost:3306/iot?serverTimezone=GMT%2B8&characterEncoding=utf-8&useSSL=false&useUnicode=true

seata:
  # 事务组名称
  tx-service-group: home-seata
  service:
    # 事务组与cluster的映射关系
    vgroup-mapping:
      home-seata: gaoxizhi
  data-source-proxy-mode: XA
  application-id: ${spring.application.name}
  # enable-auto-data-source-proxy: false
  # TC服务注册中心的配置，微服务根据这些信息去注册中心获取tc服务地址
  registry:
    # 注册中心类型 nacos
    type: nacos
    nacos:
      # nacos地址
      server-addr: 127.0.0.1:8848
      # namespace，默认为空
      namespace: gaox
      # 分组，默认是DEFAULT_GROUP
      group: home
      # seata服务名称
      application: seata-server
      username: nacos
      password: nacos

feign:
  hystrix:
    enabled: true
  client:
    config:
      default:
        connect-timeout: 5000
        read-timeout: 2000

mybatis-plus:
  typeAliasesPackage: net.gaox.domain.entity
  mapper-locations: classpath:/mybatis/**/*Mapper.xml
  configuration:
    map-underscore-to-camel-case: true
logging:
  level.net.gaox.system: debug
