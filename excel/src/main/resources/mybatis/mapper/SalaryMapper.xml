<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.gaox.excel.mapper.SalaryMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="net.gaox.excel.entity.Salary">
        <result column="emp_no" property="empNo"/>
        <result column="salary" property="salary"/>
        <result column="from_date" property="fromDate"/>
        <result column="to_date" property="toDate"/>
    </resultMap>

    <insert id="insertBatch" parameterType="java.util.Collection">
        INSERT INTO `salary` (`emp_no`, `salary`, `from_date`, `to_date`) VALUES
        <foreach collection="salaries" item="salary" separator=",">
            (#{salary.empNo}, #{salary.salary}, #{salary.fromDate}, #{salary.toDate})
        </foreach>
    </insert>

</mapper>
